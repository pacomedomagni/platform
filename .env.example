# Database Configuration
DATABASE_URL="postgresql://noslag:noslag_password@localhost:5432/noslag_db?schema=public"
POSTGRES_USER=noslag
POSTGRES_PASSWORD=noslag_password
POSTGRES_DB=noslag_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Keycloak Authentication
KEYCLOAK_ISSUER=http://localhost:8080/realms/noslag
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/noslag/protocol/openid-connect/certs
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Application Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
DOMAIN=noslag.com
FRONTEND_URL=http://localhost:4200
STORE_URL=http://localhost:4200/storefront
CORS_ORIGINS=http://localhost:4200,http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:4200
NEXT_PUBLIC_BASE_URL=http://localhost:4200
NEXT_PUBLIC_DEFAULT_CURRENCY=USD

# Security — all values below are checked at boot by env-validator.ts.
# Production will refuse to start if any are unset, below 32 chars, or
# match a known insecure default string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
CUSTOMER_JWT_SECRET=
ENCRYPTION_KEY=
LOCAL_STORAGE_SECRET=
PROVISION_API_KEY=
# ALLOW_TENANT_HEADER=true is a DEVELOPMENT-ONLY backdoor that lets the client
# set the tenant via x-tenant-id header. The env validator forbids this in prod.
ALLOW_TENANT_HEADER=true
ENABLE_DEV_PASSWORD_LOGIN=true

# S3-compatible Storage (MinIO in dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=noslag-uploads
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Email Configuration
SENDGRID_API_KEY=
SENDGRID_WEBHOOK_VERIFICATION_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=noreply@noslag.com
EMAIL_FROM_NAME="NoSlag Support"
EMAIL_FROM_ADDRESS=noreply@noslag.com

# Stripe Payment Processing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CONNECT_WEBHOOK_SECRET=
MOCK_PAYMENTS=true

# eBay Marketplace
EBAY_SANDBOX=true
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_RU_NAME=
EBAY_VERIFICATION_TOKEN=
EBAY_WEBHOOK_ENDPOINT=
MOCK_EXTERNAL_SERVICES=false

# Square Marketplace
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
SQUARE_ENVIRONMENT=sandbox

# Feature Flags
ENABLE_WEBHOOKS=true
ENABLE_THEME_SYSTEM=true
ENABLE_EMAIL_QUEUE=true
SYNC_CORE_DOCTYPES=true
